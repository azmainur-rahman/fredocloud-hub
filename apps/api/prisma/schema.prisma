generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MEMBER
}

enum GoalStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum ItemStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String
  name         String
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships   WorkspaceMember[]
  goalsOwned    Goal[]                 @relation("GoalOwner")
  announcements Announcement[]         @relation("AnnouncementAuthor")
  actionItems   ActionItem[]           @relation("ActionItemAssignee")
  auditLogs     AuditLog[]
  notifications Notification[]
  goalUpdates   GoalUpdate[]
  comments      AnnouncementComment[]
  reactions     AnnouncementReaction[]
  attachments   Attachment[]
}

model Workspace {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String
  accentColor String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members       WorkspaceMember[]
  goals         Goal[]
  announcements Announcement[]
  auditLogs     AuditLog[]
  goalUpdates   GoalUpdate[]
  attachments   Attachment[]

  @@index([name])
}

model WorkspaceMember {
  userId      String   @db.Uuid
  workspaceId String   @db.Uuid
  role        Role     @default(MEMBER)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@id([userId, workspaceId])
  @@index([workspaceId, role])
}

model Goal {
  id          String     @id @default(uuid()) @db.Uuid
  title       String
  description String
  status      GoalStatus @default(PENDING)
  dueDate     DateTime
  ownerId     String     @db.Uuid
  workspaceId String     @db.Uuid
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  owner       User         @relation("GoalOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  milestones  Milestone[]
  actionItems ActionItem[]
  updates     GoalUpdate[]

  @@index([workspaceId, status])
  @@index([ownerId])
  @@index([dueDate])
}

model Milestone {
  id                 String   @id @default(uuid()) @db.Uuid
  title              String
  progressPercentage Int      @default(0)
  goalId             String   @db.Uuid
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
}

model Announcement {
  id          String   @id @default(uuid()) @db.Uuid
  content     String
  pinned      Boolean  @default(false)
  authorId    String   @db.Uuid
  workspaceId String   @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author    User                   @relation("AnnouncementAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  workspace Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  comments  AnnouncementComment[]
  reactions AnnouncementReaction[]

  @@index([workspaceId, pinned])
  @@index([authorId])
}

model GoalUpdate {
  id          String   @id @default(uuid()) @db.Uuid
  content     String
  goalId      String   @db.Uuid
  authorId    String   @db.Uuid
  workspaceId String   @db.Uuid
  createdAt   DateTime @default(now())

  goal      Goal      @relation(fields: [goalId], references: [id], onDelete: Cascade)
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([goalId, createdAt])
  @@index([workspaceId, createdAt])
}

model AnnouncementComment {
  id             String   @id @default(uuid()) @db.Uuid
  content        String
  announcementId String   @db.Uuid
  authorId       String   @db.Uuid
  createdAt      DateTime @default(now())

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  author       User         @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([announcementId, createdAt])
  @@index([authorId])
}

model AnnouncementReaction {
  id             String   @id @default(uuid()) @db.Uuid
  emoji          String
  announcementId String   @db.Uuid
  userId         String   @db.Uuid
  createdAt      DateTime @default(now())

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId, emoji])
  @@index([announcementId])
  @@index([userId])
}

model ActionItem {
  id         String     @id @default(uuid()) @db.Uuid
  title      String
  priority   Priority   @default(MEDIUM)
  status     ItemStatus @default(TODO)
  dueDate    DateTime
  assigneeId String     @db.Uuid
  goalId     String     @db.Uuid
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  assignee User @relation("ActionItemAssignee", fields: [assigneeId], references: [id], onDelete: Cascade)
  goal     Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId, status])
  @@index([assigneeId, status])
  @@index([dueDate])
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  action      String
  details     Json
  userId      String   @db.Uuid
  workspaceId String   @db.Uuid
  timestamp   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, timestamp])
  @@index([userId])
  @@index([action])
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  message   String
  read      Boolean  @default(false)
  userId    String   @db.Uuid
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
}

model Attachment {
  id          String   @id @default(uuid()) @db.Uuid
  url         String
  publicId    String
  fileName    String
  fileType    String
  entityType  String
  entityId    String
  uploaderId  String   @db.Uuid
  workspaceId String   @db.Uuid
  createdAt   DateTime @default(now())

  uploader  User      @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, entityType, entityId])
  @@index([uploaderId])
}
